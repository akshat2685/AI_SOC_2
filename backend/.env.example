# Required Credentials (MUST be provided)
GEMINI_API_KEY=your_gemini_api_key_here
SOAR_API_KEY=your_soar_api_key_here
SOAR_API_ENDPOINT=https://api.example.com/v1/containment

# Database Connections
DATABASE_URL=postgresql://soc_user:soc_password@localhost:5432/soc_db
POSTGRES_URL=postgresql://soc_user:soc_password@localhost:5432/soc_db
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Messaging & Storage
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
NEO4J_URI=bolt://localhost:7687
NEO4J_AUTH=neo4j/password_in_production

# Application Settings
PROJECT_NAME="ShieldAI SOC Engine"
LOG_LEVEL=INFO
DEBUG=False
SECRET_KEY=your-super-secret-jwt-key-here
AUDIT_SECRET_KEY=your-super-secret-audit-key-here
RATE_LIMIT_ENABLED=True
RATE_LIMIT_STORAGE_URL=memory://
