# ==============================================================================
# ShieldAI (EDYSOR) Autonomous AI SOC 2 Platform - Environment Configuration
# ==============================================================================
# LEGEND:
#   [REQUIRED] = Application will fail to start if not set
#   [OPTIONAL] = Sensible default exists, override if needed
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. AI Engine & Gemini LLM API Keys  [REQUIRED]
# ------------------------------------------------------------------------------
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# ------------------------------------------------------------------------------
# 2. Authentication & System Secrets  [REQUIRED]
# ------------------------------------------------------------------------------
SECRET_KEY=change_this_to_a_random_64_char_hex_string
AUDIT_SECRET_KEY=change_this_to_a_random_64_char_hex_string
GF_ADMIN_PASSWORD=change_this_to_a_strong_password

# ------------------------------------------------------------------------------
# 3. Database Credentials & Connection Endpoints  [REQUIRED]
# ------------------------------------------------------------------------------
# PostgreSQL (Relational Transactional Store)
POSTGRES_USER=soc
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=soc
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_URL=postgresql://soc:changeme_in_production@postgres:5432/soc

# ------------------------------------------------------------------------------
# 4. SOAR Automation Engine  [REQUIRED]
# ------------------------------------------------------------------------------
SOAR_API_KEY=change_to_a_secure_uuid
SOAR_API_ENDPOINT=https://your-soar-api.example.com/v1/containment

# ------------------------------------------------------------------------------
# 5. Infrastructure Services  [OPTIONAL - defaults work in Docker Compose]
# ------------------------------------------------------------------------------
# Redis (Cache & Rate Limiter)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ClickHouse (OLAP Security Event Store)
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=changeme_clickhouse

# Neo4j (Attack Chain & Asset Topology Graph)
NEO4J_URI=bolt://neo4j:7687
NEO4J_AUTH=neo4j/password_in_production

# Qdrant (Vector Database for RAG & Incident Memory)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333

# Apache Kafka (Real-Time Telemetry Bus)  [REQUIRED]
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ------------------------------------------------------------------------------
# 6. Observability & Secrets Management  [OPTIONAL]
# ------------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root

# ------------------------------------------------------------------------------
# 7. External SaaS Notification Webhooks  [OPTIONAL]
# ------------------------------------------------------------------------------
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# PAGERDUTY_INTEGRATION_KEY=your_pagerduty_key
